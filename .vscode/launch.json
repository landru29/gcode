{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "DXF",
            "cargo": {
                "args": [
                    "build",
                    "--bin=gcode",
                    "--package=gcode"
                ],
                "filter": {
                    "name": "gcode",
                    "kind": "bin"
                },
            },
            "args": ["path", "--dxf", "testdata/file.dxf", "--security-z", "5.0", "--feed", "100.0"],
            "cwd": "${workspaceFolder}"
        }
    ]
}