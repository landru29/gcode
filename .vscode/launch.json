{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Path",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build",
                    "--bin=gcode",
                    "--package=gcode"
                ],
                "filter": {
                    "name": "gcode",
                    "kind": "bin"
                },
            },
            "args": [
                "path", 
                "--dxf", "testdata/file.dxf", 
                "--security-z", "5.0", 
                "--feed", "100.0", 
                "--entities", "point,arc",
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Drill",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build",
                    "--bin=gcode",
                    "--package=gcode"
                ],
                "filter": {
                    "name": "gcode",
                    "kind": "bin"
                },
            },
            "args": [
                "drill", 
                "--dxf", "testdata/file.dxf", 
                "--security-z", "5.0", 
                "--feed", "100.0", 
                "--entities", "point,line",
            ],
            "cwd": "${workspaceFolder}"
        }
    ]
}